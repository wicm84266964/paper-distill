# Optional standalone paper-distill defaults.
# Keep real keys in your shell environment or an untracked local env file.
# The mock backend needs no API service and is suitable for smoke tests.
PAPER_DISTILL_BACKEND=mock

# For real generation, use an OpenAI-compatible chat completions endpoint.
# PAPER_DISTILL_BACKEND=openai-compatible
# PAPER_DISTILL_MODEL=<model name>
# PAPER_DISTILL_BASE_URL=<https://provider.example/v1>
# PAPER_DISTILL_API_KEY=<api key>
